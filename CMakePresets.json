{
  "version": 6,

  "configurePresets": [
{
  "name": "default",
  "generator": "Ninja",
  "binaryDir": "build",
  "installDir": "${fileDir}/build/local",
  "cacheVariables": {
    "nc4fortran_warning_as_error": true,
    "nc4fortran_BUILD_TESTING": true,
    "CMAKE_BUILD_TYPE": "Release"
  }
},
{ "name": "debug", "inherits": "default",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug"
  }
},
{
  "name": "reldebug", "inherits": "default",
  "displayName": "release with debug info",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "RelWithDebInfo"
  }
},
{ "name": "shared", "inherits": "reldebug",
  "displayName": "build shared libraries",
  "cacheVariables": {
    "BUILD_SHARED_LIBS": true,
    "nc4fortran_ENABLE_RPATH": true,
    "FETCHCONTENT_TRY_FIND_PACKAGE_MODE": "NEVER"
  }
},
{
  "name": "nofind", "inherits": "reldebug",
  "displayName": "don't find  NetCDF",
  "cacheVariables": {
    "FETCHCONTENT_TRY_FIND_PACKAGE_MODE": "NEVER"
  }
},
{
  "name": "coverage",
  "binaryDir": "build-${presetName}",
  "displayName": "Code Coverage",
  "description": "Build with code coverage enabled.",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug",
    "nc4fortran_coverage": true
  }
}
],
"buildPresets": [
  { "name": "default", "configurePreset": "default" },
  { "name": "nofind",  "configurePreset": "nofind", "inherits": "default" },
  { "name": "shared",  "configurePreset": "shared", "inherits": "default" },
  {
    "name": "explain",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "explain"]
  },
  {
    "name": "keep",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "keeprsp", "-d", "keepdepfile"]
  },
  {
    "name": "stats",
    "configurePreset": "default",
    "nativeToolOptions": ["-d", "stats"]
  },
  {
    "name": "reldebug",
    "configurePreset": "reldebug",
    "displayName": "Release with Debug Info"
  },
  { "name": "debug", "configurePreset": "debug" },
  { "name": "coverage", "configurePreset": "coverage" },
  {
    "name": "run-coverage",
    "configurePreset": "coverage",
    "targets": "coverage"
  }
],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "output": {
    "outputOnFailure": true,
    "verbosity": "verbose"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false,
    "jobs": 4,
    "timeout": 60
  }
},
{ "name": "nofind", "configurePreset": "nofind", "inherits": "default" },
{ "name": "shared", "configurePreset": "shared", "inherits": "default" },
{
  "name": "reldebug", "inherits": "default",
  "configurePreset": "reldebug",
  "displayName": "Release with Debug Info"
},
{ "name": "debug", "inherits": "default", "configurePreset": "debug" }
],
"workflowPresets": [
  {
    "name": "default",
    "steps": [
      { "type": "configure", "name": "default" },
      { "type": "build", "name": "default" },
      { "type": "test", "name": "default" }
    ]
  },
  {
    "name": "build",
    "steps": [
      { "type": "configure", "name": "default" },
      { "type": "build", "name": "default" }
    ]
  },
  {
    "name": "debug",
    "steps": [
      { "type": "configure", "name": "debug" },
      { "type": "build", "name": "debug" },
      { "type": "test", "name": "debug" }
    ]
  },
  {
    "name": "reldebug",
    "steps": [
      { "type": "configure", "name": "reldebug" },
      { "type": "build", "name": "reldebug" },
      { "type": "test", "name": "reldebug" }
    ]
  },
  {
    "name": "shared",
    "steps": [
      { "type": "configure", "name": "shared" },
      { "type": "build", "name": "shared" },
      { "type": "test", "name": "shared" }
    ]
  },
  {
    "name": "nofind",
    "steps": [
      { "type": "configure", "name": "nofind" },
      { "type": "build", "name": "nofind" },
      { "type": "test", "name": "nofind" }
    ]
  }
]
}
